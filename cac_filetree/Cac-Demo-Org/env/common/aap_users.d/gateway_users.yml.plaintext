  # ==============================================================
  # Additional User Examples (Commented - For Reference)
  # ==============================================================

  # Example: External LDAP/SAML User (no password needed)
  # - username: external-user@company.com
  #   email: external-user@company.com
  #   first_name: External
  #   last_name: User
  #   is_superuser: false
  #   is_system_auditor: false
  #   # No password field - authentication handled by LDAP/SAML

  # Example: Temporary User with Expiration (manual removal needed)
  # - username: temp-contractor
  #   password: !vault |
  #         $ANSIBLE_VAULT;1.1;AES256
  #         ...vault content...
  #   email: contractor@temp.com
  #   first_name: Temporary
  #   last_name: Contractor
  #   is_superuser: false
  #   is_system_auditor: false
  #   update_secrets: true
  #   # Note: AAP doesn't have built-in expiration - set reminder to remove

  # Example: Team Lead with Specific Organization
  # - username: team-lead-ops
  #   password: !vault |
  #         $ANSIBLE_VAULT;1.1;AES256
  #         ...vault content...
  #   email: teamlead@example.com
  #   first_name: Operations
  #   last_name: TeamLead
  #   is_superuser: false
  #   is_system_auditor: false
  #   update_secrets: "{{ user_update_secrets | default(false) | bool }}"
  #   # Organization/team membership managed via gateway_role_user_assignments

  # Example: Read-only User (permissions via RBAC)
  # - username: readonly-viewer
  #   password: !vault |
  #         $ANSIBLE_VAULT;1.1;AES256
  #         ...vault content...
  #   email: viewer@example.com
  #   first_name: ReadOnly
  #   last_name: Viewer
  #   is_superuser: false
  #   is_system_auditor: false
  #   update_secrets: false
  #   # Assign read-only roles via gateway_role_user_assignments

# ==============================================================
# Important Notes:
# ==============================================================
#
# 1. Vaulting Passwords:
#    Generate with: ansible-vault encrypt_string 'YourPassword123' --name 'password'
#    Or with vault file: ansible-vault encrypt_string 'Password' --vault-password-file .vault_pass.txt
#
# 2. update_secrets Parameter:
#    - true: Always update password on every CaC run
#    - false: Only set password on user creation, never update
#    - "{{ user_update_secrets | default(false) | bool }}": Controlled by variable
#
#    Usage with variable:
#    ansible-playbook configure-aap.yaml -e "user_update_secrets=true"
#
# 3. Password Rotation:
#    - Set update_secrets=true when rotating passwords
#    - Run CaC playbook to update
#    - Set back to false to prevent accidental changes
#
# 4. User Types:
#    - is_superuser: true = Full platform admin (use sparingly!)
#    - is_system_auditor: true = Read-only across entire platform
#    - Regular user: Both false, permissions via RBAC
#
# 5. Service Accounts:
#    - Use descriptive names (svc-*, sa-*, etc.)
#    - Always use vaulted passwords
#    - Assign minimal required permissions
#    - Document purpose and owner
#
# 6. External Authentication (LDAP/SAML):
#    - Create user records without password field
#    - Authentication handled by external system
#    - Use same username as in LDAP/SAML
#
# 7. Applying with Vault:
#    ansible-playbook playbooks/configure-aap-using-filetree.yaml \
#      -e "orgs=Cac-Demo-Org" \
#      -e "env=common" \
#      --vault-password-file .vault_pass.txt \
#      --tags users
#
# 8. Security Best Practices:
#    - Never commit unvaulted passwords
#    - Use unique passwords per user
#    - Rotate service account passwords regularly
#    - Limit superuser accounts (max 2-3)
#    - Enable MFA in AAP settings (not in CaC)
#
# ==============================================================

# controller_user_accounts:
